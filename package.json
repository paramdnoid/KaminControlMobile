{
  "name": "kamincontrolmobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "babel-preset-expo": "~56.0.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-linking": "~56.0.13",
    "expo-print": "~56.0.3",
    "expo-router": "~56.2.9",
    "expo-sharing": "~56.0.16",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "jszip": "^3.10.1",
    "lucide-react-native": "^1.17.0",
    "mdb-reader": "^3.2.0",
    "nativewind": "^4.2.5",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "read-excel-file": "^9.0.10",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "electron": "^42.3.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "smoke:web": "expo export --platform web --output-dir .claude/tmp/expo-web-smoke --clear",
    "typecheck": "tsc --noEmit && npm run converter:typecheck",
    "converter:typecheck": "tsc -p desktop-converter/tsconfig.json --noEmit",
    "converter:build": "vite build --config desktop-converter/vite.config.ts",
    "converter:start": "npm run converter:build && NODE_OPTIONS=\"--require tsx/cjs\" electron desktop-converter/electron/main.ts",
    "converter:convert": "tsx desktop-converter/scripts/convert.ts",
    "converter:test": "tsx desktop-converter/tests/genesisConverter.test.ts",
    "test:search": "tsx src/utils/search.test.ts",
    "claude:validate-schema": "node .claude/hooks/validate_claude_settings_schema.cjs",
    "claude:test-hooks": "python3 .claude/hooks/test_guards.py",
    "claude:validate-config": "python3 .claude/hooks/validate_claude_config.py",
    "claude:validate-settings": "npm run claude:validate-schema && npm run claude:validate-config",
    "lint": "eslint 'app/**/*.{ts,tsx}' 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'app/**/*.{ts,tsx}' 'src/**/*.{ts,tsx}' --fix"
  },
  "private": true
}
