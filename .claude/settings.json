{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": { "bgIsolation": "worktree" },
  "autoMemoryEnabled": true,
  "cleanupPeriodDays": 14,
  "effortLevel": "high",
  "includeGitInstructions": true,
  "showTurnDuration": true,
  "viewMode": "verbose",
  "permissions": {
    "allow": [
      "Read(./*)",
      "Read(./src/**)",
      "Read(./app/**)",
      "Read(./desktop-converter/**)",
      "Read(./assets/**)",
      "Read(./sample/**)",
      "Read(./.claude/**)",
      "Read(./.github/**)",
      "Edit(./*)",
      "Edit(./src/**)",
      "Edit(./app/**)",
      "Edit(./desktop-converter/**)",
      "Edit(./assets/**)",
      "Edit(./sample/**)",
      "Edit(./.claude/**)",
      "Edit(./.github/**)",
      "Write(./*)",
      "Write(./src/**)",
      "Write(./app/**)",
      "Write(./desktop-converter/**)",
      "Write(./assets/**)",
      "Write(./sample/**)",
      "Write(./.claude/**)",
      "Write(./.github/**)",
      "Glob",
      "Grep",
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(nl *)",
      "Bash(sed -n *)",
      "Bash(wc *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git ls-files*)",
      "Bash(npm start)",
      "Bash(npm run android)",
      "Bash(npm run ios)",
      "Bash(npm run web)",
      "Bash(npm run smoke:web)",
      "Bash(npm run typecheck)",
      "Bash(npm run converter:typecheck)",
      "Bash(npm run converter:test)",
      "Bash(npm run converter:build)",
      "Bash(npm run converter:start)",
      "Bash(npm run lint)",
      "Bash(npm run claude:validate-settings)",
      "Bash(npm run claude:test-hooks)",
      "Bash(node .claude/hooks/validate_claude_settings_schema.cjs*)",
      "Bash(python3 -m py_compile .claude/hooks/*.py)",
      "Bash(python3 .claude/hooks/test_guards.py)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.git)",
      "Read(.git/**)",
      "Read(**/.git)",
      "Read(**/.git/**)",
      "Read(./.git)",
      "Read(./.git/**)",
      "Read(./**/.git)",
      "Read(./**/.git/**)",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Read(./*.p8)",
      "Read(./*.p12)",
      "Read(./*.jks)",
      "Read(./*.mobileprovision)",
      "Read(./key.properties)",
      "Read(./**/key.properties)",
      "Read(./artifacts)",
      "Read(./artifacts/**)",
      "Read(./pdfs)",
      "Read(./pdfs/**)",
      "Read(./dist)",
      "Read(./dist/**)",
      "Read(./.desktop-build)",
      "Read(./.desktop-build/**)",
      "Read(./genesis-export-v*.json)",
      "Read(./genesis-mobile-export)",
      "Read(./genesis-mobile-export/**)",
      "Read(./genesis-mobile-export.zip)",
      "Read(./Daten.zip)",
      "Read(./*.MDB)",
      "Read(./*.mdb)",
      "Read(./*Genesis*.zip)",
      "Read(./*Sicherung*.zip)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.git)",
      "Edit(.git/**)",
      "Edit(**/.git)",
      "Edit(**/.git/**)",
      "Edit(./.git)",
      "Edit(./.git/**)",
      "Edit(./**/.git)",
      "Edit(./**/.git/**)",
      "Edit(./*.mobileprovision)",
      "Edit(./key.properties)",
      "Edit(./**/key.properties)",
      "Edit(./artifacts)",
      "Edit(./artifacts/**)",
      "Edit(./pdfs)",
      "Edit(./pdfs/**)",
      "Edit(./dist)",
      "Edit(./dist/**)",
      "Edit(./.desktop-build)",
      "Edit(./.desktop-build/**)",
      "Edit(./genesis-export-v*.json)",
      "Edit(./genesis-mobile-export)",
      "Edit(./genesis-mobile-export/**)",
      "Edit(./genesis-mobile-export.zip)",
      "Edit(./Daten.zip)",
      "Edit(./*.MDB)",
      "Edit(./*.mdb)",
      "Edit(./*Genesis*.zip)",
      "Edit(./*Sicherung*.zip)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(.git)",
      "Write(.git/**)",
      "Write(**/.git)",
      "Write(**/.git/**)",
      "Write(./.git)",
      "Write(./.git/**)",
      "Write(./**/.git)",
      "Write(./**/.git/**)",
      "Write(./*.mobileprovision)",
      "Write(./key.properties)",
      "Write(./**/key.properties)",
      "Write(./artifacts)",
      "Write(./artifacts/**)",
      "Write(./pdfs)",
      "Write(./pdfs/**)",
      "Write(./dist)",
      "Write(./dist/**)",
      "Write(./.desktop-build)",
      "Write(./.desktop-build/**)",
      "Write(./genesis-export-v*.json)",
      "Write(./genesis-mobile-export)",
      "Write(./genesis-mobile-export/**)",
      "Write(./genesis-mobile-export.zip)",
      "Write(./Daten.zip)",
      "Write(./*.MDB)",
      "Write(./*.mdb)",
      "Write(./*Genesis*.zip)",
      "Write(./*Sicherung*.zip)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(sudo *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown -R *)",
      "Bash(npm publish*)",
      "Bash(eas submit*)",
      "Bash(eas build*)",
      "Bash(expo publish*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_dangerous_commands.py"]
          }
        ]
      },
      {
        "matcher": "Read|Edit|MultiEdit|Write|Glob|Grep|LS",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_sensitive_paths.py"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/mark_validation_needed.py"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/quality_gate_stop.py"]
          }
        ]
      }
    ]
  }
}
